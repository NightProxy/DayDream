{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "baseUrl": "./src",
    "paths": {
      "@browser/*": ["browser/*"],
      "@apis/*": ["apis/*"],
      "@css/*": ["css/*"],
      "@pkgs/*": ["pkgs/*"],
      "@components/*": ["components/*"],
      "@hooks/*": ["hooks/*"],
      "@utils/*": ["utils/*"],
      "@types/*": ["types/*"],
      "@pages/*": ["pages/*"],
      "@core/*": ["core/*"],
      "@/*": ["*"],
      "@../*": ["../*"],
      "@mercuryworkshop/scramjet-controller": ["core/SJ/controller/src/index.ts"],
      "@mercuryworkshop/scramjet-utils": ["core/SJ/utils/src/index.ts"],
      "@mercuryworkshop/rpc": ["core/SJ/rpc/index.ts"]
    },
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "allowJs": true,
    "esModuleInterop": true,
  },
  "include": ["src", "public/core/client.js", "global.d.ts", "pages", "tests"],
  "exclude": [
    "node_modules",
    "dist",
    "src/lib/**",
    "src/apis/platform/hosting.hostlist.ts",
    "src/apis/platform/hosting.hostlist.uo.ts",
    "pkgs/**",
    "src/**/__sanity__/**",
    "TSX/**",
    "demo/**"
  ]
}
