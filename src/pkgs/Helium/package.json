{
  "name": "helium",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome Extension API emulation library",
  "workspaces": [
    "packages/shared",
    "packages/mv2",
    "packages/mv3"
  ],
  "scripts": {
    "build": "npm run build:shared && npm run build:mv2 && npm run build:mv3",
    "build:shared": "npm run build -w packages/shared",
    "build:mv2": "npm run build -w packages/mv2",
    "build:mv3": "npm run build -w packages/mv3",
    "generate": "node tools/generate.js"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
