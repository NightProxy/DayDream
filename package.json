{
  "name": "daydreamx",
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx devserver.ts",
    "core:dev": "vite dev --host & tsx index.ts",
    "build": "npm run neutron:build && npm run obscura:build && npm run obscura:bundle && npm run obscura:bundle:iife && npm run controller:build && npm run helium-bootstrap:build && npm run neutron-worker:build && npm run mini-chrome:build && npm run devtools-agent:build && npm run devtools-worker-agent:build && npm run nyx-bridge:build && npm run nyx-bridge-agent:build && tsc -p tsconfig.build.json && vite build",
    "neutron:build": "cd neutron && npm run build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "start": "tsx index.ts",
    "knip": "knip",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "obscura:build": "cd src/pkgs/Obscura && wasm-pack build --target web",
    "obscura:bundle": "rolldown -c src/pkgs/Obscura/rolldown.config.ts",
    "obscura:bundle:iife": "rolldown -c src/pkgs/Obscura/rolldown.iife.config.ts",
    "sw:build": "rolldown -c src/core/sw/rolldown.config.ts",
    "config:build": "rolldown -c src/core/SJ/config/rolldown.config.ts",
    "controller:build": "rolldown -c src/core/SJ/controller/rolldown.api.config.ts && rolldown -c src/core/SJ/controller/rolldown.sw.config.ts && rolldown -c src/core/SJ/controller/rolldown.inject.config.ts",
    "helium-bootstrap:build": "rolldown -c src/core/helium/bootstrap/rolldown.client.config.ts",
    "mini-chrome:build": "rolldown -c src/core/helium/content/rolldown.mini-chrome.config.ts",
    "neutron-worker:build": "rolldown -c src/core/helium/content/rolldown.neutron-worker.config.ts",
    "devtools-agent:build": "rolldown -c src/apis/devtools/agent/rolldown.config.ts",
    "devtools-worker-agent:build": "rolldown -c src/apis/devtools/worker-agent/rolldown.config.ts",
    "nyx-bridge:build": "rolldown -c src/apis/nyxBridge/client/rolldown.config.ts",
    "nyx-bridge-agent:build": "rolldown -c src/apis/nyxBridge/agent/rolldown.config.ts"
  },
  "devDependencies": {
    "@types/draggabilly": "^2.1.6",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sortablejs": "^1.15.8",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.7",
    "autoprefixer": "^10.4.21",
    "glob": "^11.0.1",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "knip": "^5.64.1",
    "opentype.js": "^1.3.4",
    "postcss": "^8.5.6",
    "prettier": "^3.5.3",
    "sass": "^1.99.0",
    "tailwindcss": "^4.1.18",
    "terser": "^5.48.0",
    "ttf2woff2": "^5.0.0",
    "typescript": "~5.9.3",
    "vite": "8.0.3",
    "vite-plugin-bundle-obfuscator": "^1.11.0",
    "vite-plugin-javascript-obfuscator": "^3.1.0",
    "vite-plugin-minify": "^2.1.0",
    "vite-plugin-static-copy": "^3.2.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@fastify/compress": "^8.1.0",
    "@fastify/deepmerge": "^3.2.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/static": "^8.2.0",
    "@jaames/iro": "^5.5.2",
    "@mercuryworkshop/epoxy-transport": "^3.0.1",
    "@mercuryworkshop/libcurl-transport": "^2.0.5",
    "@mercuryworkshop/proxy-transports": "^1.0.2",
    "@mercuryworkshop/scramjet": "https://github.com/MercuryWorkshop/scramjet/releases/download/v2.0.67-alpha.2/mercuryworkshop-scramjet-2.0.67-alpha.2.tgz",
    "@mercuryworkshop/wisp-js": "^0.3.3",
    "@nightnetwork/night-auth": "^1.2.3",
    "@nightnetwork/plus-client": "^1.0.0",
    "@tailwindcss/vite": "^4.1.12",
    "@terbiumos/tfs": "^1.0.24",
    "@types/content-type": "^1.1.9",
    "@types/uuid": "^10.0.0",
    "basecoat-css": "^0.3.2",
    "chalk": "^5.4.1",
    "chii": "^1.15.5",
    "chobitsu": "^1.8.6",
    "compression": "^1.8.0",
    "content-type": "^1.0.5",
    "eruda": "^3.4.1",
    "fastify": "^5.4.0",
    "fflate": "^0.8.3",
    "gradient-string": "^3.0.0",
    "libcurl.js": "^0.7.4",
    "lightningcss": "^1.32.0",
    "lucide": "^0.483.0",
    "neutron": "file:neutron",
    "ora": "^8.2.0",
    "rolldown": "^1.0.2",
    "sortablejs": "^1.15.6",
    "tsx": "^4.21.0",
    "uuid": "^11.1.0"
  }
}
